PORT=4002
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/node_postg_db?schema=public"

# Docker Compose only (service interpolation in docker-compose.yml).
# In-container DATABASE_URL/REDIS_HOST/RABBITMQ_URL are derived from these.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=node_postg_db
POSTGRES_PORT=5432
REDIS_INSIGHT_PORT=5540
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Authentication (JWT)
ACCESS_TOKEN_SECRET="your-access-token-secret"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
ACCESS_TOKEN_EXPIRY="1d"

# AI Services
OPENAI_API_KEY="sk-proj-your-openai-api-key"
CHAT_WONDER_API_URL="http://your-chat-wonder-api-url"

# Mailer (Ethereal for Testing)
MAILER_TRANSPORT_HOST="smtp.ethereal.email"
MAILER_TRANSPORT_PORT=587
MAILER_TRANSPORT_SECURE=false
MAILER_EMAIL="your-ethereal-email@ethereal.email"
MAILER_PASSWORD="your-ethereal-password"

# Redis Cache & Rate Limiting
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_TTL_SECONDS=3600
REDIS_TLS=false               # Set to true for managed Redis (AWS ElastiCache, Upstash)

# Worker Process
WORKER_HEALTH_PORT=8080       # Health probe port for Kubernetes/ECS — separate from API
METRICS_INTERVAL_MS=60000     # How often WorkerMetrics persists a snapshot to Redis

# AWS S3 & CloudFront
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET_NAME="your-s3-bucket-name"
S3_CDN_URL="https://your-cloudfront-id.cloudfront.net"

# RabbitMQ Configuration
RABBITMQ_URL="amqp://guest:guest@localhost:5672/"
RABBITMQ_EXCHANGE="app_events_exchange"
RABBITMQ_QUEUE_PREFIX="app"
INGESTION_QUEUE_NAME="ingestion_jobs"

# YouTube API
YOUTUBE_API_KEY="your-youtube-api-key"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_ANDROID_CLIENT_ID="your-google-android-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# WebSub Configuration
WEBSUB_CALLBACK_URL="https://your-domain.ngrok-free.app/api"
WEBSUB_SECRET="your-websub-secret"
