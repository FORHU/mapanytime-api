{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MapanytimeApiLogGroups",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:DescribeLogStreams"],
      "Resource": "arn:aws:logs:*:*:log-group:/mapanytime-api/*"
    },
    {
      "Sid": "MapanytimeApiLogStreams",
      "Effect": "Allow",
      "Action": ["logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:*:*:log-group:/mapanytime-api/*:log-stream:*"
    }
  ]
}
