generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phoneNumber     String?
  avatarId        String?           @unique
  accountStatus   USERACCOUNTSTATUS @default(ACTIVE)
  isEmailVerified Boolean           @default(false)
  isOnBoarding    Boolean           @default(false)
  countryCode     String?
  lastLoginAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  roles             Roles[]                 @relation("UserRoles")
  avatar            Files?                  @relation(fields: [avatarId], references: [id])
  session           Session[]
  seller            Sellers?
  buyer             Buyers?
  verifiedDocuments DocumentVerifications[]
  sentAdminInvites  AdminInvites[]

  @@index([email])
  @@index([accountStatus])
}

model Roles {
  id          String   @id @default(cuid())
  roleName    String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       Users[]  @relation("UserRoles")
}

enum USERACCOUNTSTATUS {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Session {
  id             String    @id @default(cuid())
  userId         String
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  refreshToken   String?   @unique
  provider       String
  accessToken    String?
  avatarUrl      String?
  providerUserId String?
  scopes         String?
  updatedAt      DateTime  @updatedAt
  users          Users     @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
}

model Files {
  id        String      @id @default(cuid())
  userId    String
  fileName  String
  fileUrl   String
  metaData  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  documents Documents[]
  products  Products[]
  users     Users?
}

model Sellers {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  applicationStatus     ApplicationStatus       @default(PENDING)
  documentVerifications DocumentVerifications[]
  users                 Users                   @relation(fields: [userId], references: [id])
  stores                Stores[]
}

model Buyers {
  id          String   @id @default(cuid())
  userId      String   @unique
  createdAt   DateTime @default(now())
  displayName String
  updatedAt   DateTime @updatedAt

  users  Users          @relation(fields: [userId], references: [id])
  review StoreReviews[]
  orders Orders[]
}

model DocumentVerifications {
  id                 String             @id @default(cuid())
  sellerId           String
  verificationStatus VerificationStatus @default(PENDING)
  verifiedById       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  storeId            String
  seller             Sellers            @relation(fields: [sellerId], references: [id])
  store              Stores             @relation(fields: [storeId], references: [id])
  verifiedByAdmin    Users?             @relation(fields: [verifiedById], references: [id])
  documents          Documents[]
}

model Documents {
  id                      String                @id @default(cuid())
  documentVerificationsId String
  fileId                  String
  documentType            DOCUMENTTYPES
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  documentVerification    DocumentVerifications @relation(fields: [documentVerificationsId], references: [id])
  files                   Files                 @relation(fields: [fileId], references: [id])
}

enum DOCUMENTTYPES {
  MAYORS_PERMIT
  TIN_ID
  DTI_CERTIFICATE
  GOV_ID
}

model AdminInvites {
  id        String       @id @default(cuid())
  email     String       @unique
  token     String       @unique
  status    INVITESTATUS @default(PENDING)
  inviterId String
  expiresAt DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  inviter   Users        @relation(fields: [inviterId], references: [id])
}

enum INVITESTATUS {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Stores {
  id                    String                  @id @default(cuid())
  sellerId              String
  storeName             String
  description           String?
  isActive              Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  documentVerifications DocumentVerifications[]
  products              Products[]
  storeHours            StoreHours[]
  storeLocations        StoreLocations?
  storeReviews          StoreReviews[]
  seller                Sellers                 @relation(fields: [sellerId], references: [id])
  categories            Categories[]            @relation("CategoriesToStores")
  orders                Orders[]
  inventory             Inventory[]

  @@index([sellerId])
  @@index([isActive])
}

model StoreHours {
  id        String   @id @default(cuid())
  storeId   String
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Stores   @relation(fields: [storeId], references: [id])
}

model StoreLocations {
  id             String   @id @default(cuid())
  storeId        String   @unique
  currentAddress String
  homeAddress    String
  city           String
  province       String
  zipCode        String
  country        String
  latitude       Float
  longitude      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  store          Stores   @relation(fields: [storeId], references: [id])

  @@index([latitude, longitude])
}

model StoreReviews {
  id        String   @id @default(cuid())
  storeId   String
  buyerId   String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Stores   @relation(fields: [storeId], references: [id])
  buyer     Buyers   @relation(fields: [buyerId], references: [id])
}

model Products {
  id            String    @id @default(cuid())
  storeId       String
  productFileId String?
  categoryId    String?
  name          String
  brand         String?
  description   String?
  price         Float
  isActive      Boolean   @default(false)
  totalSold     Int       @default(0)
  listedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store       Stores      @relation(fields: [storeId], references: [id])
  productFile Files?      @relation(fields: [productFileId], references: [id])
  category    Categories? @relation(fields: [categoryId], references: [id])
  tags        Tags[]
  inventory   Inventory[]

  @@index([storeId])
  @@index([categoryId])
  @@index([isActive])
}

model Categories {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isActive    Boolean      @default(true)
  parentId    String?
  parent      Categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Categories[] @relation("CategoryHierarchy")
  products    Products[]
  stores      Stores[]     @relation("CategoriesToStores")

  @@index([parentId])
  @@index([name])
}

model Tags {
  id        String   @id @default(cuid())
  productId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Products @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CategoryStatus {
  PENDING
  APPROVED
  REJECTED
}

model Orders {
  id          String           @id @default(cuid())
  buyerId     String
  storeId     String
  totalAmount Float
  type        FULLFILLMENTTYPE @default(PICKUP)
  status      ORDERSTATUS      @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  buyer      Buyers       @relation(fields: [buyerId], references: [id])
  store      Stores       @relation(fields: [storeId], references: [id])
  orderitems OrderItems[]
  payment    Payments[]
}

enum FULLFILLMENTTYPE {
  DELIVERY
  PICKUP
}

enum ORDERSTATUS {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

model OrderItems {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Orders @relation(fields: [orderId], references: [id])
}

model Inventory {
  id               String   @id @default(cuid())
  productId        String   @unique
  storeId          String
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Products @relation(fields: [productId], references: [id])
  store   Stores   @relation(fields: [storeId], references: [id])
}

model Payments {
  id            String        @id @default(cuid())
  orderId       String
  amount        Float
  paymentMethod PAYMENTMETHOD
  status        PAYMENTSTATUS @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Orders @relation(fields: [orderId], references: [id])
}

enum PAYMENTMETHOD {
  BANK
  GCASH
  CASH_ON_DELIVERY
}

enum PAYMENTSTATUS {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
