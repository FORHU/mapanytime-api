generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  id              String            @id @default(cuid())
  email           String            @unique
  passwordHash    String
  firstName       String?
  lastName        String?
  phoneNumber     String?
  roles           Roles[]           @relation("UserRoles")
  avatarId        String?           @unique
  accountStatus   USERACCOUNTSTATUS @default(ACTIVE)
  isEmailVerified Boolean           @default(false)
  isOnBoarding    Boolean           @default(false)
  countryCode     String?
  lastLoginAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt


  avatar            Files?                  @relation(fields: [avatarId], references: [id])
  session           Session[]
  seller            Sellers?
  buyer             Buyers?
  verifiedDocuments DocumentVerifications[]
  sentAdminInvites  AdminInvites[]

  @@index([email])
  @@index([accountStatus])
}


model Roles {
  id          String   @id @default(cuid())
  roleName    String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users Users[] @relation("UserRoles")
}


enum USERACCOUNTSTATUS {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}


model Session {
  id             String    @id @default(cuid())
  userId         String
  provider       String
  providerUserId String?
  accessToken    String?
  refreshToken   String?   @unique
  expiresAt      DateTime?
  scopes         String?
  avatarUrl      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users Users @relation(fields: [userId], references: [id])

  // Ensures no two different users can link the exact same external social account
  @@unique([provider, providerUserId])
}

model Files {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  fileUrl   String
  metaData  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     Users?

  documents Documents[]
  products  Products[]
}

model Sellers {
  id                String            @id @default(cuid())
  userId            String            @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  applicationStatus ApplicationStatus @default(PENDING)

  users                 Users                   @relation(fields: [userId], references: [id])
  documentVerifications DocumentVerifications[]
  stores                Stores[]
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Buyers {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users Users @relation(fields: [userId], references: [id])
  review   StoreReviews[]
  orders   Orders[]
}

model DocumentVerifications {
  id                 String             @id @default(cuid())
  sellerId           String
  storeId            String // CHANGED: Added to link the document to a specific branch
  verificationStatus VerificationStatus @default(PENDING)
  verifiedById       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  seller          Sellers     @relation(fields: [sellerId], references: [id])
  store           Stores      @relation(fields: [storeId], references: [id])
  documents       Documents[]
  verifiedByAdmin Users?      @relation(fields: [verifiedById], references: [id])
}


enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Documents {
  id                      String        @id @default(cuid())
  documentVerificationsId String
  fileId                  String
  documentType            DOCUMENTTYPES
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  documentVerification DocumentVerifications @relation(fields: [documentVerificationsId], references: [id])
  files                Files                 @relation(fields: [fileId], references: [id])

}


enum DOCUMENTTYPES {
  MAYORS_PERMIT
  TIN_ID
  DTI_CERTIFICATE
  GOV_ID
}

model AdminInvites {
  id        String       @id @default(cuid())
  email     String       @unique // Ensures only one active invite per email
  token     String       @unique // The secure random string sent in the email link
  status    INVITESTATUS @default(PENDING)
  inviterId String // The ID of the Admin who created this invite
  expiresAt DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  inviter Users @relation(fields: [inviterId], references: [id])
}


enum INVITESTATUS {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Stores {
  id          String   @id @default(cuid())
  sellerId    String 
  storeName   String
  description String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller                Sellers                 @relation(fields: [sellerId], references: [id])
  storeHours            StoreHours[]
  storeLocations        StoreLocations?
  storeReviews          StoreReviews[]
  products              Products[]
  documentVerifications DocumentVerifications[] 
  categories            Categories[]
  orders                Orders[]
  //inventory             Inventory[]

  @@index([sellerId])
  @@index([isActive])
}

model StoreHours {
  id        String   @id @default(cuid())
  storeId   String
  dayOfWeek Int // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  openTime  String // Format: "HH:mm"
  closeTime String // Format: "HH:mm"
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Stores @relation(fields: [storeId], references: [id])
}

model StoreLocations {
  id             String   @id @default(cuid())
  storeId        String   @unique
  currentAddress String
  homeAddress    String
  city           String
  province       String
  zipCode        String
  country        String
  latitude       Float
  longitude      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store Stores @relation(fields: [storeId], references: [id])
  @@index([latitude, longitude])
}

model StoreReviews {
  id        String   @id @default(cuid())
  storeId   String
  buyerId   String
  rating    Int // e.g., 1 to 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Stores @relation(fields: [storeId], references: [id])
  buyer     Buyers      @relation(fields: [buyerId], references: [id])
}

model Products {
  id            String    @id @default(cuid())
  storeId       String
  productFileId String?
  categoryId    String?
  name          String
  brand         String?
  description   String?
  price         Float
  isActive      Boolean   @default(false)
  listedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store       Stores      @relation(fields: [storeId], references: [id])
  productFile Files?      @relation(fields: [productFileId], references: [id])
  category    Categories? @relation(fields: [categoryId], references: [id])
  tags        Tags[]
  //inventory   Inventory[]

  @@index([storeId])
  @@index([categoryId])
  @@index([isActive])
}

model Categories {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  parentId    String? 
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())     
  updatedAt   DateTime     @updatedAt

  parent      Categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Categories[] @relation("CategoryHierarchy")

  products    Products[]
  stores      Stores[]     // Implicit Many-to-Many relation for stores selecting their parent categories

  @@index([parentId]) 
  @@index([name])
}

model Tags {
  id        String   @id @default(cuid())
  productId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Products @relation(fields: [productId], references: [id], onDelete: Cascade)

  
}

model Orders {
  id          String    @id @default(cuid())
  buyerId     String
  storeId     String
  totalAmount Float
  type        FULLFILLMENTTYPE @default(PICKUP)
  status      ORDERSTATUS @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  buyer      Buyers      @relation(fields: [buyerId], references: [id])
  store      Stores      @relation(fields: [storeId], references: [id])
  orderitems  OrderItems[]
  payment    Payments[]

}

enum FULLFILLMENTTYPE {
  DELIVERY
  PICKUP
}

enum ORDERSTATUS {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

model OrderItems {
  id        String    @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Orders    @relation(fields: [orderId], references: [id])
}

/*model Inventory {
  id        String    @id @default(cuid())
  productId String
  storeId   String
  quantityOnHand    Int @default(0)
  quantityReserved  Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Products @relation(fields: [productId], references: [id])
  store   Stores   @relation(fields: [storeId], references: [id])
}*/

model Payments {
  id       String    @id @default(cuid())
  orderId  String
  amount   Float
  paymentMethod PAYMENTMETHOD
  status   PAYMENTSTATUS @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Orders @relation(fields: [orderId], references: [id])
}

enum PAYMENTMETHOD {
  BANK
  GCASH
  CASH_ON_DELIVERY
}

enum PAYMENTSTATUS {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
 